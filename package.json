{
  "name": "Testes_Android",
  "type": "module",
  "devDependencies": {
    "@wdio/allure-reporter": "^9.30.0",
    "@wdio/appium-service": "^9.30.0",
    "@wdio/cli": "^9.30.0",
    "@wdio/local-runner": "^9.30.0",
    "@wdio/mocha-framework": "^9.30.0",
    "appium-uiautomator2-driver": "^8.1.0"
  },
  "scripts": {
    "test": "wdio run ./wdio.conf.js",
    "report": "allure generate allure-results --clean -o allure-report",
    "login:report":"wdio run ./wdio.conf.js --suite login",
    "checkout:report":"wdio run ./wdio.conf.js --suite checkout && npm run report",
    "busca:report":"wdio run ./wdio.conf.js --suite busca",
    "test:report":"npm run test && npm run report"
  },
  "dependencies": {
    "dotenv": "^17.4.2"
  }
}
